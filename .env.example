# Storyblok
NEXT_PUBLIC_STORYBLOK_CONTENT_API_ACCESS_TOKEN=your_token_here
NEXT_PUBLIC_STORYBLOK_REGION='eu'

# JWT Secret (generate your own)
JWT_SECRET=your_jwt_secret_here

# 数据库类型: postgres (默认) 或 mysql
DB_TYPE=postgres

# ==========================================
# Neon PostgreSQL (Vercel 部署使用)
# 在 Vercel 上连接 Neon 后会自动设置
# ==========================================
# DATABASE_URL=postgresql://...

# ==========================================
# 本地 PostgreSQL 配置 (可选)
# ==========================================
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=
# PG_DATABASE=storyblok
